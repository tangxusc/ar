[
{{- $any := false}}
{{- if arg .args "install_istio"}}
{{- $any = true}}
  {
    "name": "push-images-istio",
    "description": "жҺЁйҖҒistioзҰ»зәҝй•ңеғҸеҲ°з§Ғжңүд»“еә“",
    "image": "istio-installer:1.29.1",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/image-push.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      "install-istio-crd"
    ]
  },
  {
    "name": "install-istio-crd",
    "description": "е®үиЈ…istio-crd",
    "image": "istio-installer:1.29.1",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install istio-base /ar/base-1.29.1.tgz --version 1.29.1 --namespace istio-system --create-namespace --wait"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ],
    "nodes": [
      "install-istiod"
    ]
  },
  {
    "name": "install-istiod",
    "description": "е®үиЈ…istio-istiod",
    "image": "istio-installer:1.29.1",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install istiod /ar/istiod-1.29.1.tgz --version 1.29.1 --namespace istio-system --create-namespace --wait"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ],
    "nodes": [
      "install-istio-gateway"
    ]
  },
  {
    "name": "install-istio-gateway",
    "description": "е®үиЈ…istio-gateway",
    "image": "istio-installer:1.29.1",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install istio-gateway /ar/gateway-1.29.1.tgz --version 1.29.1 --namespace istio-system --create-namespace --wait"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ]
  }
{{- end}}
{{- if arg .args "install_automq"}}
{{- if $any}},{{end}}
{{- $any = true}}
  {
    "name": "push-images-automq",
    "description": "жҺЁйҖҒAutoMQ(Strimzi)зҰ»зәҝй•ңеғҸеҲ°з§Ғжңүд»“еә“",
    "image": "automq-installer:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/image-push.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      "install-automq"
    ]
  },
  {
    "name": "install-automq",
    "description": "е®үиЈ…AutoMQ(еҹәдәҺStrimzi Kafka Operator)",
    "image": "automq-installer:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install automq-strimzi-operator /ar/strimzi-kafka-operator-0.47.0.tgz --namespace automq --create-namespace --wait"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ]
  }
{{- end}}
{{- if arg .args "install_flink"}}
{{- if $any}},{{end}}
{{- $any = true}}
  {
    "name": "push-images-flink",
    "description": "жҺЁйҖҒFlinkзҰ»зәҝй•ңеғҸеҲ°з§Ғжңүд»“еә“",
    "image": "flink-installer:1.11.0",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/image-push.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      "install-flink"
    ]
  },
  {
    "name": "install-flink",
    "description": "е®үиЈ…Flink Kubernetes Operator",
    "image": "flink-installer:1.11.0",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install flink-kubernetes-operator /ar/flink-kubernetes-operator-1.11.0.tgz --namespace flink --create-namespace --wait --set webhook.create=false --set defaultConfiguration.taskmanager.numberOfTaskSlots=2"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ]
  }
{{- end}}
{{- if arg .args "install_risingwave"}}
{{- if $any}},{{end}}
{{- $any = true}}
  {
    "name": "push-images-risingwave",
    "description": "жҺЁйҖҒRisingWaveзҰ»зәҝй•ңеғҸеҲ°з§Ғжңүд»“еә“",
    "image": "risingwave-installer:v2.6.0",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/image-push.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      "install-risingwave"
    ]
  },
  {
    "name": "install-risingwave",
    "description": "е®үиЈ…RisingWaveжөҒејҸж•°жҚ®еә“",
    "image": "risingwave-installer:v2.6.0",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install risingwave /ar/risingwave-*.tgz --namespace risingwave --create-namespace --wait --set metaStore.etcd.enabled=true --set stateStore.s3.enabled=true --set stateStore.s3.endpoint={{arg .args "s3_endpoint"}} --set stateStore.s3.bucket={{arg .args "s3_bucket_risingwave"}} --set stateStore.s3.accessKey={{arg .args "s3_access_key"}} --set stateStore.s3.secretKey={{arg .args "s3_secret_key"}}"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ]
  }
{{- end}}
{{- if arg .args "install_deepflow"}}
{{- if $any}},{{end}}
  {
    "name": "push-images-deepflow",
    "description": "жҺЁйҖҒDeepFlowзҰ»зәҝй•ңеғҸеҲ°з§Ғжңүд»“еә“",
    "image": "deepflow-installer:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/image-push.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      "install-deepflow"
    ]
  },
  {
    "name": "install-deepflow",
    "description": "е®үиЈ…DeepFlowзҪ‘з»ңеҸҜи§ӮжөӢжҖ§е№іеҸ°",
    "image": "deepflow-installer:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "helm upgrade --install deepflow /ar/deepflow-*.tgz --namespace deepflow --create-namespace --wait --set global.storageClass={{arg .args "rbd_storage_class"}}"
    ],
    "env": [
      "KUBECONFIG=/ar-data/kubeconfig/master.kubeconfig"
    ]
  }
{{- end}}
]
