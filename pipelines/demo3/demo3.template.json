[
    {
        "name": "alpine",
        "image": "alpine:latest",
        "entrypoint": "cat",
        "args": [
            "/etc/os-release",
            "/etc/hosts"
        ],
        "env": [
            "env1=value1",
            "env2=value2"
        ],
        "nodes": [
            "step2-1","step2-2"
        ]
    },
    {
        "name": "step2-1",
        "image": "alpine:latest",
        "entrypoint": "bash",
        "args": [
            "-c",
            "echo step2-1",
            "sleep 5s"
        ],
        "nodes": [
            "step3"
        ]
    },
    {
        "name": "step2-2",
        "image": "alpine:latest",
        "entrypoint": "bash",
        "args": [
            "-c",
            "echo step2-2",
            "sleep 10s"
        ],
        "nodes": [
            "step3"
        ]
    },
    {
        "name": "step3",
        "image": "alpine:latest",
        "entrypoint": "echo",
        "args": [
            "step3"
        ]
    }
]