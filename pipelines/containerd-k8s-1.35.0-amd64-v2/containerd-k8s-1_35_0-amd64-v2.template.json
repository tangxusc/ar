[
  {
    "name": "start",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "echo",
    "args": [
      "start"
    ],
    "nodes": [
        "print-pipeline-execution-plan"
    ]
  },
  {
    "name": "print-pipeline-execution-plan",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "cat",
    "args": ["/tasks/pipeline.json"],
    "nodes": [
        {{range $i, $n := .nodes}}{{if $i}}, {{end}}"copy-artifacts-{{$i}}"{{end}}
    ]
  },
  {{range $i, $n := .nodes}}
  {
    "name": "copy-artifacts-{{$i}}",
    "description": "复制artifacts",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "rsync",
      "-avzc",
      "-e",
      "ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
      "/ar/",
      "{{$n.Username}}@{{$n.IP}}:/tmp/ar/"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      "disable-swap-{{$i}}"
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "disable-swap-{{$i}}",
    "description": "禁用swap",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo sed -ri 's/.*swap.*/#&/' /etc/fstab && sudo swapoff -a && sudo sysctl -w vm.swappiness=0&& cat /etc/fstab"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      "adjust-ulimit-{{$i}}"
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "adjust-ulimit-{{$i}}",
    "description": "调整ulimit",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo cp /tmp/ar/confs/limits.conf /etc/security/limits.conf && ulimit -SHn 65535 && sudo cat /etc/security/limits.conf"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
        "install-ipvs-{{$i}}"
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "install-ipvs-{{$i}}",
    "description": "安装ipvs",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo apt install ipvsadm ipset sysstat conntrack -y && sudo cp /tmp/ar/confs/ipvs.conf /etc/modules-load.d/ipvs.conf &&sudo systemctl restart systemd-modules-load.service &&sudo lsmod | grep -e ip_vs -e nf_conntrack"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
        "adjust-k8s-conf-{{$i}}"
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "adjust-k8s-conf-{{$i}}",
    "description": "调整k8s内核配置",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo cp /tmp/ar/confs/k8s.conf /etc/sysctl.d/k8s.conf && sudo sysctl -p && sudo cat /etc/sysctl.d/k8s.conf"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
        "install-containerd-{{$i}}"
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "install-containerd-{{$i}}",
    "description": "安装containerd",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo sh /tmp/ar/scripts/install-containerd.sh"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{if gt (len (ipsByLabel $.nodes "registry" "true")) 0}}"render-registry-hosts"{{else}}"install-lvs-care-{{$i}}"{{end}}
    ]
  },
  {{end}}
  {{if gt (len (ipsByLabel .nodes "registry" "true")) 0}}
  {
    "name": "render-registry-hosts",
    "description": "渲染镜像仓库 hosts.toml",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/render-image-registry-hosts.sh {{join "," (getNodeFieldValueByLabel .nodes "registry" "true" "IntranetIP")}} {{arg .args "registry_auth_username"}} {{arg .args "registry_auth_password"}}"
    ],
    "nodes": [
      {{range $i, $n := .nodes}}{{if $i}}, {{end}}"distribute-registry-hosts-{{$i}}"{{end}}
    ]
  },
  {{range $i, $n := .nodes}}
  {
    "name": "distribute-registry-hosts-{{$i}}",
    "description": "分发镜像仓库 hosts.toml",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "rsync",
      "-avzc",
      "-e",
      "ssh -p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
      "/ar-data/confs/registry/hosts.toml",
      "{{$n.Username}}@{{$n.IP}}:/tmp/ar/confs/image-registry/hosts.toml"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{range $j, $ip := (ipsByLabel $.nodes "registry" "true")}}{{if $j}}, {{end}}"install-image-registry-{{$ip}}"{{end}}
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}{{if labelHas $n.LabelsStr "registry" "true"}}
  {
    "name": "install-image-registry-{{$n.IP}}",
    "description": "安装镜像仓库",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo bash /tmp/ar/scripts/image-registry-install.sh"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{range $j, $m := $.nodes}}{{if $j}}, {{end}}"configure-containerd-registry-{{$j}}"{{end}}
    ]
  },
  {{end}}{{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "configure-containerd-registry-{{$i}}",
    "description": "配置 containerd registry mirror",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo mkdir -p /etc/containerd/certs.d/_default && sudo cp /tmp/ar/confs/image-registry/hosts.toml /etc/containerd/certs.d/_default/hosts.toml && sudo systemctl restart containerd"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{range $j, $m := $.nodes}}{{if $j}}, {{end}}"install-lvs-care-{{$j}}"{{end}}
    ]
  },
  {{end}}
  {{end}}
  {{range $i, $n := .nodes}}
  {
    "name": "install-lvs-care-{{$i}}",
    "description": "安装lvs-care",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo bash /tmp/ar/scripts/install-lvs-care.sh {{join "," (getNodeFieldValueByLabel $.nodes "role" "master" "IntranetIP")}} {{arg $.args "lvs_care_vip"}}"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      "gen-ca-pem"
    ]
  },
  {{end}}
  {
    "name": "gen-ca-pem",
    "description": "生成ca证书",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/gen-pem/gen-ca-pem.sh"
    ],
    "nodes": [
        "gen-etcd-config"
    ]
  },
  {
    "name": "gen-etcd-config",
    "description": "生成etcd配置",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/gen-etcd-config.sh {{join "," (getNodeFieldValueByLabel .nodes "etcd" "true" "IntranetIP")}}"
    ],
    "nodes": [
      {{if gt (len (ipsByLabel .nodes "etcd" "true")) 0}}
        {{range $i, $ip := (ipsByLabel .nodes "etcd" "true")}}{{if $i}}, {{end}}"copy-etcd-certs-{{$ip}}"{{end}}
      {{end}}
    ]
  },
  {{range $i, $n := .nodes}}{{if labelHas $n.LabelsStr "etcd" "true"}}
  {
    "name": "copy-etcd-certs-{{$n.IP}}",
    "description": "复制生成的证书和配置到目标主机",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "rsync",
      "-avzc",
      "-e",
      "ssh -p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
      "/ar-data/",
      "{{$n.Username}}@{{$n.IP}}:/tmp/ar/"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{if gt (len (ipsByLabel $.nodes "etcd" "true")) 0}}
        {{range $i, $ip := (ipsByLabel $.nodes "etcd" "true")}}{{if $i}}, {{end}}"install-etcd-{{$ip}}"{{end}}
      {{end}}
    ]
  },
  {{end}}{{end}}
  {{range $i, $n := .nodes}}{{if labelHas $n.LabelsStr "etcd" "true"}}
  {
    "name": "install-etcd-{{$n.IP}}",
    "description": "安装etcd",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo sh /tmp/ar/scripts/install-etcd.sh {{$n.IntranetIP}}"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      "gen-k8s-certs"
    ]
  },
  {{end}}{{end}}
  {
    "name": "gen-k8s-certs",
    "description": "生成K8s组件证书和kubeconfig",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "bash",
    "args": [
      "-lcx",
      "/ar/scripts/generate-certs.sh {{join "," (getNodeFieldValueByLabel .nodes "role" "master" "IntranetIP")}} {{join "," (getNodeFieldValueByLabel .nodes "etcd" "true" "IntranetIP")}} {{arg .args "lvs_care_vip"}} {{join "," (getNodeFieldValueByLabel .nodes "role" "master" "IP")}}"
    ],
    "nodes": [
      {{range $i, $n := .nodes}}{{if $i}}, {{end}}"copy-k8s-certs-{{$i}}"{{end}}
    ]
  },
  {{range $i, $n := .nodes}}
  {
    "name": "copy-k8s-certs-{{$i}}",
    "description": "拷贝K8s证书和kubeconfig到节点{{$n.IP}}",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "rsync",
      "-avzc",
      "-e",
      "ssh -p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
      "/ar-data/",
      "{{$n.Username}}@{{$n.IP}}:/tmp/ar/"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{if labelHas $n.LabelsStr "role" "master"}}"install-master-{{$i}}"{{else}}{{range $j, $idx := (indicesByLabel $.nodes "role" "master")}}{{if $j}}, {{end}}"install-master-{{$idx}}"{{end}}{{end}}
    ]
  },
  {{end}}
  {{range $i, $n := .nodes}}{{if labelHas $n.LabelsStr "role" "master"}}
  {
    "name": "install-master-{{$i}}",
    "description": "安装K8s master组件 {{$n.IP}}",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo bash /tmp/ar/scripts/install-master.sh {{$n.IntranetIP}} {{join "," (getNodeFieldValueByLabel $.nodes "etcd" "true" "IntranetIP")}} {{$n.LabelsStr}} {{if eq $i 0}}true{{else}}false{{end}}"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      {{range $j, $idx := (indicesByNotLabel $.nodes "role" "master")}}{{if $j}}, {{end}}"install-node-{{$idx}}"{{end}}{{if gt (len (indicesByNotLabel $.nodes "role" "master")) 0}}, {{end}}"apply-node-labels"
    ]
  },
  {{end}}{{end}}
  {{range $i, $n := .nodes}}{{if not (labelHas $n.LabelsStr "role" "master")}}
  {
    "name": "install-node-{{$i}}",
    "description": "安装K8s node组件 {{$n.IP}}",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{if $n.Port}}{{$n.Port}}{{else}}22{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{$n.Username}}@{{$n.IP}}",
      "sudo bash /tmp/ar/scripts/install-node.sh {{$n.IntranetIP}} {{$n.LabelsStr}}"
    ],
    "env": ["SSHPASS={{$n.Password}}"],
    "nodes": [
      "apply-node-labels"
    ]
  },
  {{end}}{{end}}
  {
    "name": "apply-node-labels",
    "description": "在master上为所有节点应用labels",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "sshpass",
    "args": [
      "-e",
      "ssh",
      "-p {{with index .nodes 0}}{{if .Port}}{{.Port}}{{else}}22{{end}}{{end}}",
      "-o",
      "StrictHostKeyChecking=no",
      "-o",
      "UserKnownHostsFile=/dev/null",
      "{{with index .nodes 0}}{{.Username}}@{{.IP}}{{end}}",
      "sudo bash /tmp/ar/scripts/apply-labels.sh {{range $i, $n := .nodes}}{{if $i}} {{end}}{{$n.IntranetIP}}:{{$n.LabelsStr}}{{end}}"
    ],
    "env": ["SSHPASS={{with index .nodes 0}}{{.Password}}{{end}}"],
    "nodes": [
      "end"
    ]
  },
  {
    "name": "end",
    "image": "containerd-k8s-1_35_0-base:latest",
    "entrypoint": "echo",
    "args": [
      "end"
    ]
  }
]
