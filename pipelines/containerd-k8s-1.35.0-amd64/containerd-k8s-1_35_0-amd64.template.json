[
    {
        "name": "print-pipeline-execution-plan",
        "image": "containerd-k8s-1_35_0-base:latest",
        "entrypoint": "cat",
        "args": [
            "/tasks/pipeline.json"
        ],
        "nodes": ["init-node"]
    },
    {
        "name": "init-node",
        "description": "禁用swap,调整ulimit",
        "image": "containerd-k8s-1_35_0-base:latest",
        "entrypoint": "sshpass",
        "args": [
            "-e",
            "ssh",
            "-o",
            "StrictHostKeyChecking=no",
            "-o",
            "UserKnownHostsFile=/dev/null",
            "{{node_username}}@{{node_ip}}",
            "cat /etc/hosts"
        ],
        "env": [
            "SSHPASS={{node_password}}"
        ]
    }
]