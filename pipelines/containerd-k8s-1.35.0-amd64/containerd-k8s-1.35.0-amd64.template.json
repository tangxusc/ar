[
    {
        "name": "打印执行计划",
        "image": "containerd-k8s-1.35.0-base:latest",
        "entrypoint": "cat",
        "args": [
            "/task/pipeline.json"
        ],
        "nodes": ["初始化节点"]
    },
    {
        "name": "初始化节点",
        "image": "containerd-k8s-1.35.0-base:latest",
        "entrypoint": "sshpass",
        "args": [
            "-e",
            "ssh",
            "-o",
            "StrictHostKeyChecking=no",
            "-o",
            "UserKnownHostsFile=/dev/null",
            "${node_username}@${node_ip}",
            "cat /etc/hosts"
        ],
        "env": [
            "SSHPASS={{node_password}}",
            "node_username={{node_username}}",
            "node_ip={{node_ip}}"
        ]
    }
]